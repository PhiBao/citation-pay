NEXT_PUBLIC_APP_URL=http://localhost:3000
PAYMENT_MODE=real

# Supabase is optional for local mock demos. Add these for persistent deploys.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Required for the autonomous paying agent.
BUYER_PRIVATE_KEY=
BUYER_ADDRESS=
CIRCLE_FACILITATOR_URL=https://gateway-api-testnet.circle.com
ARC_TESTNET_NETWORK=eip155:5042002
ARC_RPC_URL=

# Optional Circle Wallet API configuration. The current x402 flow uses
# BUYER_PRIVATE_KEY; these are tracked for Arc/Circle operational checks.
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
CIRCLE_WALLET_ID=

# Optional. Without this, the agent produces deterministic extractive answers.
OPENAI_API_KEY=

# Required in production to protect publisher/feed setup.
ADMIN_TOKEN=

# Public per-run spend cap in micro USDC. 1000 = $0.001000.
MAX_PUBLIC_BUDGET_MICRO_USDC=1000
