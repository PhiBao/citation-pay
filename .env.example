NEXT_PUBLIC_APP_URL=http://localhost:3000
PAYMENT_MODE=real

# Supabase is optional for local mock demos. Add these for persistent deploys.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Required for platform settlement. Users never receive this key.
PLATFORM_SETTLEMENT_PRIVATE_KEY=
PLATFORM_SETTLEMENT_ADDRESS=
CIRCLE_FACILITATOR_URL=https://gateway-api-testnet.circle.com
ARC_TESTNET_NETWORK=eip155:5042002
ARC_RPC_URL=

# Optional Circle Wallet API configuration for account funding operations.
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
CIRCLE_WALLET_ID=

# Optional. Without DGrid, the agent produces deterministic extractive answers.
DGRID_API_KEY=
DGRID_MODEL=openai/gpt-4o
DGRID_BASE_URL=https://api.dgrid.ai/v1

# Required in production to protect publisher/feed setup.
ADMIN_TOKEN=

# Trial account and spend limits in micro USDC. 1000 = $0.001000.
TRIAL_CREDIT_MICRO_USDC=1000
DEFAULT_PER_RUN_LIMIT_MICRO_USDC=1000
DEFAULT_DAILY_LIMIT_MICRO_USDC=10000
MAX_PUBLIC_BUDGET_MICRO_USDC=1000
